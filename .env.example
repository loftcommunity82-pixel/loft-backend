# =============================================================================
# Loft API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Database ---
# PostgreSQL connection string (Neon, Supabase, RDS, etc.)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# --- Auth ---
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-here"

# --- Frontend ---
# The URL of the deployed frontend (used for CORS origin + email links)
FRONTEND_URL="http://localhost:3000"

# --- Email (Resend) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# --- Support ---
# Where contact form submissions are forwarded
SUPPORT_EMAIL="support@loftcommunity.com"

# --- Stripe (optional) ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Server ---
PORT=4000
NODE_ENV=development
